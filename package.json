{
  "name": "next-supabase-agent-harness",
  "version": "0.1.0",
  "description": "Deterministic agent harness for Next.js 16 + Supabase: Claude Code hooks, security-invariant lint gates, RLS isolation tests, provenance pipeline, and supply-chain-hardened CI — installable into any new or existing project.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BhodiSea/next-supabase-agent-harness.git"
  },
  "bin": {
    "next-supabase-agent-harness": "installer/cli.mjs"
  },
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "files": [
    "installer",
    "template",
    "CHANGELOG.md"
  ],
  "scripts": {
    "bootstrap": "node installer/cli.mjs init --consume",
    "test": "node --test \"tests/**/*.test.mjs\""
  },
  "keywords": [
    "claude-code",
    "agent-harness",
    "nextjs",
    "supabase",
    "rls",
    "quality-gates",
    "provenance",
    "supply-chain"
  ]
}
