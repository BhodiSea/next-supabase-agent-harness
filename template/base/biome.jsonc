{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "assist": {
    "actions": { "source": { "organizeImports": "on", "useSortedKeys": "on" } },
    "enabled": true
  },
  "css": {
    "formatter": { "enabled": true },
    "parser": { "tailwindDirectives": true }
  },
  // docs/** is reference material, not source (Biome 2.4+ parses .html, so any imported
  // reference HTML under docs/ must be excluded here).
  // database.types.ts is generated by `supabase gen types` — exclude from formatting/lint so its
  // upstream style (double quotes) is preserved and a `gen types --check` drift compare stays clean.
  "files": {
    "ignoreUnknown": true,
    "includes": ["**", "!docs", "!lib/supabase/database.types.ts"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded",
      "trailingCommas": "all"
    }
  },
  "linter": {
    "domains": {
      "next": "recommended",
      "react": "recommended",
      "test": "recommended"
    },
    "enabled": true,
    "rules": {
      // The authoritative a11y linter is ESLint jsx-a11y (the strict tier in eslint.config.ts), which is
      // recalibrated (harness/a11y-scrollable-region) to ALLOW tabIndex on role="region" — the W3C ACT
      // scrollable-region pattern — and on tabIndex={-1} skip-link targets. Biome's redundant copy is not
      // role-aware, so it false-positives on both; disable it here so the two linters don't disagree.
      // SOURCE: docs/harness/README.md (a11y scrollable-region lint recalibration)
      "a11y": { "noNoninteractiveTabindex": "off" },
      // Conflicts with tsconfig noPropertyAccessFromIndexSignature (TS4111), which
      // REQUIRES bracket access on index signatures (e.g. process.env['X']). tsc wins.
      "complexity": { "useLiteralKeys": "off" },
      "preset": "recommended",
      // Tailwind v4 uses @import/@theme/@custom-variant/@utility/@apply at-rules Biome does not recognize.
      "suspicious": { "noUnknownAtRules": "off" }
    }
  },
  "overrides": [
    {
      "includes": ["**/*.test.{ts,tsx}", "**/__tests__/**", "e2e/**", "tests/**"],
      "linter": { "rules": { "suspicious": { "noConsole": "off" } } }
    }
  ],
  "vcs": {
    "clientKind": "git",
    "defaultBranch": "{{DEFAULT_BRANCH}}",
    "enabled": true,
    "useIgnoreFile": true
  }
}
