# Supabase public client configuration — from your project's dashboard: Settings > API.
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# The publishable (anon) key is safe to expose to the browser — Row Level Security
# is the authorization boundary, never this key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
