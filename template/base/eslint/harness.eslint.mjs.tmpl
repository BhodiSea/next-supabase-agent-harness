// eslint/harness.eslint.mjs
// Composable flat config (ESLint 9) for the Next.js 16 + Supabase harness.
// Biome formats; ESLint does framework + type-aware + security + architecture
// + the house limits. The default install consumes this from eslint.config.mjs
// as `export default harnessEslint()`; retrofits spread the returned array into
// an existing flat config.

import js from '@eslint/js'
import { defineConfig, globalIgnores } from 'eslint/config'
import nextVitals from 'eslint-config-next/core-web-vitals'
import nextTs from 'eslint-config-next/typescript'
import prettier from 'eslint-config-prettier/flat'
import boundaries from 'eslint-plugin-boundaries'
import jsxA11y from 'eslint-plugin-jsx-a11y'
import noSecrets from 'eslint-plugin-no-secrets'
import noUnsanitized from 'eslint-plugin-no-unsanitized'
import security from 'eslint-plugin-security'
import tseslint from 'typescript-eslint'

/**
 * Build the harness lint layer as a flat-config array.
 *
 * @param {object}   [options]
 * @param {string[]} [options.srcRoots] App-code roots (default `['app', 'components', 'lib']`).
 *   Architecture boundaries and the house size limits are scoped to these.
 * @param {string}   [options.proxyFile] The request-routing entry file (default `'proxy.ts'` —
 *   Next 16's renamed middleware). It is never an authorization boundary.
 * @returns {import('eslint').Linter.Config[]} Flat-config array (spreadable).
 */
export function harnessEslint(options = {}) {
  const { srcRoots = ['app', 'components', 'lib'], proxyFile = 'proxy.ts' } = options
  // In the boundaries vocabulary the app-router root is "bespoke" product code;
  // every other source root keeps its own name as its element type.
  const elementType = (root) => (root === 'app' ? 'bespoke' : root)

  return defineConfig([
    // .claude/** and tools/** are operational tooling (Node hook/MCP scripts) that
    // intentionally contain invariant patterns as strings — not app code to type-lint.
    globalIgnores([
      '.next/**',
      'out/**',
      'build/**',
      'coverage/**',
      '.stryker-tmp/**',
      'playwright-report/**',
      'test-results/**',
      'next-env.d.ts',
      // Generated by `supabase gen types` — not hand-authored; skip size/style/type-lint.
      // SOURCE: docs/harness/README.md (generated types exemption) [corpus: supabase/generating-types]
      'lib/supabase/database.types.ts',
      '.claude/**',
      'tools/**',
      // Supabase Edge Functions are deployed Deno code (npm:/jsr: specifiers, Deno globals) on a
      // separate toolchain — not part of the Next app graph. They are the one sanctioned home for
      // the admin key; if your project adopts that carve-out, record it in your own ADR under
      // docs/adr/ and lint the functions with Deno, not here.
      // SOURCE: docs/harness/README.md (Edge Function admin-key carve-out)
      'supabase/functions/**',
    ]),

    js.configs.recommended,
    ...nextVitals,
    ...nextTs,

    // Type-aware layer (scoped to TS/TSX)
    {
      extends: [tseslint.configs.strictTypeChecked, tseslint.configs.stylisticTypeChecked],
      files: ['**/*.{ts,tsx}'],
      languageOptions: {
        parserOptions: {
          projectService: true,
          // This file lives one level below the project root (eslint/). ESLint resolves the
          // relative globs in this config against the invocation cwd (the project root), so
          // the project service anchors there too.
          tsconfigRootDir: process.cwd(),
        },
      },
      rules: {
        // pairs with tsconfig verbatimModuleSyntax (makes value/type boundary explicit)
        '@typescript-eslint/consistent-type-imports': 'error',
      },
    },

    // Disable type-aware rules on JS/MJS config files + any root TS config files
    // (eslint/next/tailwind/postcss configs import untyped plugins).
    {
      extends: [tseslint.configs.disableTypeChecked],
      files: ['**/*.{js,mjs,cjs}', '*.config.{ts,mts,cts}', 'eslint.config.ts'],
    },

    // a11y strict (WCAG 2.2 AA). eslint-config-next already REGISTERS the jsx-a11y
    // plugin and the full react/react-hooks (incl. all React Compiler) rules — we
    // must NOT re-register those plugins (flat config forbids redefining a plugin
    // name). So we only LAYER the stricter jsx-a11y rule set on top.
    {
      files: ['**/*.{jsx,tsx}'],
      rules: { ...jsxA11y.flatConfigs.strict.rules },
    },

    // a11y recalibration: the strict default of `no-noninteractive-tabindex` forbids tabindex on
    // a non-interactive div — a mis-calibration that leaves scrollable data regions NOT
    // keyboard-reachable. The W3C-sanctioned pattern for a scrollable region is role="region" +
    // tabindex="0" + an accessible name, so we allow tabindex on role region/tabpanel. This is a
    // single-rule override (it merges/replaces cleanly across flat blocks, unlike
    // no-restricted-syntax). SOURCE: W3C ACT rule 0ssw9k (scrollable element is keyboard accessible)
    {
      files: ['**/*.{jsx,tsx}'],
      name: 'harness/a11y-scrollable-region',
      rules: {
        'jsx-a11y/no-noninteractive-tabindex': [
          'error',
          // A named <section> IS the region landmark; allow it (and explicit role region/tabpanel)
          // to be a focusable scroll region — Biome's useSemanticElements prefers <section> over
          // <div role="region">.
          { allowExpressionValues: true, roles: ['tabpanel', 'region'], tags: ['section'] },
        ],
      },
    },

    // Architecture boundaries (per-file, editor-time feedback).
    // `default: 'allow'` + targeted `disallow` edges so it stays a graceful no-op
    // until lib/dal/ + packages/kernel/ exist.
    {
      plugins: { boundaries },
      rules: {
        // v5 rule name. v6 renames this to `boundaries/dependencies` — pin v5.
        'boundaries/element-types': [
          'error',
          {
            default: 'allow',
            rules: [
              {
                disallow: ['dal'],
                from: ['client'],
                message: 'Client components must not import the server-only DAL ({{to.type}}).',
              },
              {
                disallow: srcRoots.map(elementType),
                from: ['kernel'],
                message: 'Kernel must not depend on bespoke app code.',
              },
            ],
          },
        ],
      },
      settings: {
        'boundaries/elements': [
          { pattern: 'lib/dal/**/*', type: 'dal' },
          { pattern: 'packages/kernel/**/*', type: 'kernel' },
          { pattern: '**/*.client.tsx', type: 'client' },
          ...srcRoots.map((root) => ({ pattern: `${root}/**/*`, type: elementType(root) })),
        ],
        'boundaries/include': srcRoots.map((root) => `${root}/**/*`),
      },
    },

    // Security plugins
    {
      plugins: {
        'no-secrets': noSecrets,
        'no-unsanitized': noUnsanitized,
        security,
      },
      rules: {
        ...security.configs.recommended.rules,
        'no-secrets/no-secrets': ['error', { tolerance: 4.2 }],
        'no-unsanitized/method': 'error',
        'no-unsanitized/property': 'error',
      },
    },

    // Server-only security invariants (getSession ban, service_role ban).
    // lib/dal/**, **/actions.ts, **/server/** are forward slots that may match nothing yet.
    {
      files: [
        'app/**/route.ts',
        proxyFile,
        'lib/supabase/server.ts',
        'lib/supabase/proxy.ts',
        'lib/dal/**/*.{ts,tsx}',
        '**/actions.ts',
        '**/server/**/*.{ts,tsx}',
      ],
      name: 'harness/server-invariants',
      rules: {
        'no-restricted-properties': ['error', { property: 'SUPABASE_SERVICE_ROLE_KEY' }],
        'no-restricted-syntax': [
          'error',
          {
            // SOURCE: docs/harness/README.md (getSession reads unverified cookie data server-side)
            // [corpus: supabase/getclaims]
            message:
              'Do not use getSession() server-side — it reads unverified cookie data. Use getClaims() or getUser().',
            selector: "CallExpression[callee.property.name='getSession']",
          },
          {
            message: 'Service-role key/string bypasses RLS and must never appear in app/test code.',
            selector: 'Literal[value=/service_role|SUPABASE_SERVICE_ROLE_KEY/]',
          },
          {
            message: 'Do not reference the service-role key here.',
            selector: "Identifier[name='SUPABASE_SERVICE_ROLE_KEY']",
          },
          {
            message: 'Do not read process.env.SUPABASE_SERVICE_ROLE_KEY in this layer.',
            selector: "MemberExpression[property.name='SUPABASE_SERVICE_ROLE_KEY']",
          },
        ],
      },
    },

    // Client/JSX invariants (mutually-exclusive files vs the server block, because
    // no-restricted-syntax options do not array-merge across flat-config blocks).
    {
      files: ['**/*.tsx'],
      name: 'harness/client-invariants',
      rules: {
        'no-restricted-syntax': [
          'error',
          {
            message:
              'dangerouslySetInnerHTML is forbidden — sanitize and render text, or get security review.',
            selector: "JSXAttribute[name.name='dangerouslySetInnerHTML']",
          },
        ],
      },
    },

    // The proxy file is NEVER the authorization boundary (post-CVE-2025-29927 the
    // x-middleware-subrequest header is spoofable). Optimistic session-presence
    // checks only; authorize in the DAL, close to the data.
    // SOURCE: docs/harness/README.md (proxy is not an auth boundary) [corpus: nextjs@16/proxy-cve-2025-29927]
    {
      files: [proxyFile],
      rules: {
        '@typescript-eslint/no-restricted-imports': [
          'error',
          {
            patterns: [
              {
                group: ['**/lib/dal/**', '**/lib/auth/**'],
                message:
                  'The proxy file is NOT the authorization boundary. Optimistic session-presence checks only; authorize in the DAL.',
              },
            ],
          },
        ],
      },
    },

    // no-secrets (entropy net) fires on this layer's own AST-selector strings
    // (the service-role selectors above) and on config files generally — those
    // are selectors, not secrets. Scope the rule off here only.
    {
      files: ['eslint.config.{ts,mjs}', 'eslint/**', '**/*.config.{ts,mts,cts}'],
      name: 'harness/config-no-secrets-off',
      rules: { 'no-secrets/no-secrets': 'off' },
    },

    // House hard limits: file/function length (app code only). ERRORS by design.
    {
      files: srcRoots.map((root) => `${root}/**/*.{ts,tsx}`),
      name: 'harness/size-limits',
      rules: {
        // ESLint's core "lines per file" rule is `max-lines` (there is no
        // `max-lines-per-file`). `max-lines-per-function` is the per-function rule.
        'max-lines': ['error', { max: 200, skipBlankLines: true, skipComments: true }],
        'max-lines-per-function': [
          'error',
          { IIFEs: true, max: 50, skipBlankLines: true, skipComments: true },
        ],
      },
    },

    // Test files: the house size limits are app-code discipline, not test discipline.
    // Tests are intentionally long (it.each tables, fixtures, multi-assertion specs).
    {
      files: ['tests/**', 'e2e/**', '**/*.test.{ts,tsx}', '**/__tests__/**'],
      name: 'harness/tests-size-limits-off',
      rules: {
        'max-lines': 'off',
        'max-lines-per-function': 'off',
      },
    },

    // RAZOR-SCOPED to tests/rls/** ONLY. The cross-tenant RLS suite must read the
    // service-role key (dynamically, from process.env) to seed fixtures; the GLOBAL
    // no-secrets entropy rule flags the env-var NAME. The path-scoped
    // harness/server-invariants block does NOT match tests/rls, so it is untouched.
    // SOURCE: docs/harness/README.md (RLS test-suite service-role carve-out)
    {
      files: ['tests/rls/**'],
      name: 'harness/rls-no-secrets-off',
      rules: { 'no-secrets/no-secrets': 'off' },
    },

    prettier, // MUST be last
  ])
}

export default harnessEslint
