# CODEOWNERS — mandatory human review for security/regulated surfaces.
# Pair with branch protection (require review + the quality-gate checks) so the gate
# cannot be skipped. SOURCE: docs/harness/README.md (mandatory human review).
# NOTE: the installer substitutes the tokens — {{GITHUB_OWNER}} is your GitHub user/org
# (the catch-all default owner) and {{SECURITY_OWNERS}} is the @handle(s) / @org/team(s)
# that must sign off on security surfaces (may be several, space-separated). If you are
# editing this file by hand, replace both tokens with real handles.

# Default owner for everything.
*                           @{{GITHUB_OWNER}}

# Auth / data / tenancy boundaries — REQUIRE sign-off.
/lib/supabase/**            {{SECURITY_OWNERS}}
/lib/dal/**                 {{SECURITY_OWNERS}}
/proxy.ts                   {{SECURITY_OWNERS}}
/supabase/migrations/**     {{SECURITY_OWNERS}}
/app/auth/**                {{SECURITY_OWNERS}}

# The harness itself — changes to enforcement need review.
/.claude/**                 {{SECURITY_OWNERS}}
/.harness/**                {{SECURITY_OWNERS}}
/.github/**                 {{SECURITY_OWNERS}}
/tools/**                   {{SECURITY_OWNERS}}
/eslint/**                  {{SECURITY_OWNERS}}
/eslint.config.ts           {{SECURITY_OWNERS}}
/biome.jsonc                {{SECURITY_OWNERS}}
/tsconfig.json              {{SECURITY_OWNERS}}
