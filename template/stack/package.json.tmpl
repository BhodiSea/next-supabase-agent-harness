{
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.0",
    "clsx": "^2.1.1",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "^2.5.2",
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@eslint/js": "^9",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@playwright/test": "^1.61.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.9",
    "cspell": "^10.0.1",
    "dependency-cruiser": "^16",
    "eslint": "^9",
    "eslint-config-next": "^16",
    "eslint-config-prettier": "^10",
    "eslint-plugin-boundaries": "^5",
    "eslint-plugin-jsx-a11y": "^6.10",
    "eslint-plugin-no-secrets": "^2",
    "eslint-plugin-no-unsanitized": "^4",
    "eslint-plugin-react-hooks": "^7",
    "eslint-plugin-security": "^3",
    "jiti": "^2",
    "jsdom": "^29.1.1",
    "knip": "^5",
    "lefthook": "^1.7",
    "pg": "^8.22.0",
    "postcss": "^8",
    "prettier": "^3",
    "prettier-plugin-tailwindcss": "^0.6",
    "tailwindcss": "^4.3.2",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22"
  },
  "name": "{{PROJECT_SLUG}}",
  "packageManager": "pnpm@11.10.0",
  "private": true,
  "scripts": {
    "arch": "depcruise app components lib proxy.ts --config .dependency-cruiser.js",
    "build": "next build",
    "check": "biome check --write .",
    "check:sources": "node tools/check-sources.mjs",
    "check:types:drift": "node tools/check-types-drift.mjs",
    "dev": "next dev",
    "format": "prettier --write \"**/*.tsx\" && biome format --write .",
    "format:check": "biome format . && prettier --check \"**/*.tsx\"",
    "gen:types": "supabase gen types typescript --local --schema public > lib/supabase/database.types.ts",
    "knip": "knip --strict",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "lefthook install",
    "spell": "cspell --no-progress --gitignore \"**/*.{md,ts,tsx,mjs}\"",
    "start": "next start",
    "test": "vitest run --passWithNoTests",
    "test:a11y": "node tests/a11y/run-a11y.mjs",
    "test:cov": "vitest run --coverage --passWithNoTests",
    "test:e2e": "playwright test",
    "test:migrations": "node tests/migrations/apply-rollback.mjs",
    "test:mutation": "stryker run",
    "test:mutation:inc": "stryker run stryker.incremental.mjs",
    "test:rls": "node tests/rls/run-rls.mjs",
    "test:unit": "vitest run tests/unit lib --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "validate": "node tools/validate.mjs"
  }
}
